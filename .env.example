# ============================================================================
# Zahnfunnel — Konfiguration
# Kopiere nach .env (`cp .env.example .env`) und trage deine Werte ein.
# docker-compose liest Postgres-Werte automatisch; die App liest .env via
# pydantic-settings.
# ============================================================================

# --- Postgres ---------------------------------------------------------------
POSTGRES_DB=zahnfunnel
POSTGRES_USER=zahnfunnel
POSTGRES_PASSWORD=123456789
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# --- App Server -------------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Verzögerung in Minuten zwischen Lead-Eingang und Versand der personalisierten
# Antwort (WhatsApp/Mail). Setze auf 0 für sofortigen Versand (z.B. beim Testen).
CONTACT_DELAY_MINUTES=3

# Optional: Shared Secret für POST /webhook/form. Wenn gesetzt, MUSS deine
# Website den Header `X-Api-Key: <wert>` mitschicken. Leer lassen = offen.
# Empfohlen: 32+ zufällige Zeichen, z.B. via `openssl rand -hex 32`.
FORM_API_KEY=

# --- Anthropic --------------------------------------------------------------
ANTHROPIC_API_KEY=
# Stabiler Alias. Alternativen: claude-sonnet-4-6 (neuer), claude-opus-4-6
# (teurer, besser), claude-haiku-4-5-20251001 (günstiger).
ANTHROPIC_MODEL=claude-sonnet-4-5

# --- WhatsApp Cloud API (Meta Graph API) ------------------------------------
# https://developers.facebook.com/docs/whatsapp/cloud-api
WA_GRAPH_API_VERSION=v21.0
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=
# Frei wählbares Token das Meta beim Webhook-Setup zurückspielt
WA_VERIFY_TOKEN=change_this_to_something_random
# *** KRITISCH *** Meta App Secret aus App → Settings → Basic → App Secret.
# Ohne den können wir die Echtheit eingehender Webhooks NICHT prüfen.
# Der Webhook-Endpoint lehnt alle POSTs ohne gültige X-Hub-Signature-256 ab.
WA_APP_SECRET=
# Approved Template Name + Sprache (siehe Meta Business Manager)
WA_TEMPLATE_NAME=lead_intro_de
WA_TEMPLATE_LANG=de

# --- Gmail API (OAuth) ------------------------------------------------------
# 1. https://console.cloud.google.com → Projekt → Gmail API enablen
# 2. OAuth-Client-ID (Typ: Desktop) erstellen → credentials JSON runterladen
# 3. Die JSON-Datei nach ./secrets/gmail_credentials.json legen
# 4. Einmalig `python -m app.scripts.gmail_authorize` ausführen
#    → Browser öffnet sich, Login, Token wird nach ./secrets/gmail_token.json gespeichert
GMAIL_CREDENTIALS_FILE=./secrets/gmail_credentials.json
GMAIL_TOKEN_FILE=./secrets/gmail_token.json
GMAIL_FROM_ADDRESS=praxis@example.com
GMAIL_FROM_NAME=Musterpraxis

# --- Praxis-Branding (für AI-Prompts + Templates) ---------------------------
PRAXIS_NAME=Musterpraxis
PRAXIS_STADT=Musterstadt
